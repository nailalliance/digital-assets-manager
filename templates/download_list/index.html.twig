{% extends 'base.html.twig' %}

{% import '_macros/file_size.html.twig' as fileSizeMacro %}

{% block title %}Download Bag{% endblock %}

{% block body %}
    <div
        data-controller="share-link permalink-generator download-bag-script"
        data-permalink-generator-base-url-value="{{ app.request.schemeAndHttpHost }}"
        data-permalink-generator-share-endpoint-value="{{ path('download_list_share') }}"
        data-download-bag-script-initial-script-value="{{ scriptDraft|default('')|e('html_attr') }}"
    >
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-3xl font-bold text-gray-900">Download Bag</h1>
            <div class="flex items-center space-x-3">
                {% if is_granted('ROLE_FTP_DESIGNER') and assets is not empty %}
                    <button data-action="click->share-link#openShareModal" class="inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700">
                        <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                        Generate Share Link
                    </button>

                    <button type="button" data-action="click->permalink-generator#openModal"
                            class="flex flex-col items-center justify-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                        <div class="inline-flex">
                            <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                            Generate Web Links
                        </div>
                        <span class="text-xs">(from jpg|png only)</span>
                    </button>
                {% endif %}

                {% if assets is not empty %}
                    <button type="button" data-action="click->download-bag-script#openModal" class="inline-flex items-center justify-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                        <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                        Apply Script to Bag
                    </button>
                    <a href="{{ path('download_list_zip') }}" data-turbo="false" class="inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-violet-600 hover:bg-violet-700">
                        <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                        Download All (.zip)
                    </a>
                {% endif %}
            </div>
        </div>

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 rounded-md border px-4 py-3 text-sm
                    {% if type == 'success' %}
                        border-green-200 bg-green-50 text-green-800
                    {% elseif type == 'warning' %}
                        border-amber-200 bg-amber-50 text-amber-900
                    {% elseif type == 'error' %}
                        border-red-200 bg-red-50 text-red-800
                    {% else %}
                        border-slate-200 bg-white text-slate-700
                    {% endif %}
                ">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div data-permalink-generator-target="expiryNotice" class="hidden mb-6 rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
            <span data-permalink-generator-target="expiryText"></span>
        </div>

        <div data-permalink-generator-target="csvButtonContainer" class="hidden mb-6 flex justify-end">
            <button type="button" data-action="click->permalink-generator#downloadCsv" class="inline-flex items-center justify-center px-6 py-3 border border-gray-300 text-base font-medium rounded-md text-green-700 bg-green-100 hover:bg-green-200">
                <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                Download Links as CSV
            </button>
        </div>

        <div class="bg-white rounded-lg shadow-xl">
            {% if assets is not empty %}
                <ul role="list" class="divide-y divide-gray-200">
                    {% for asset in assets %}
                        <li class="p-4 sm:p-6 relative"
                            data-download-bag-script-item="true"
                            {% if asset.mimeType in ['image/jpeg', 'image/png', 'image/webp', 'image/gif'] %}
                                data-bag-script-compatible="true"
                            {% endif %}
                            {% if asset.mimeType in ['image/jpeg', 'image/png', 'image/webp', 'application/pdf'] %}
                                data-image-asset="true"
                                data-asset-id="{{ asset.id }}"
                                data-filename="{{ asset.filePath|basename }}"
                                data-sku="{{ asset.itemCodes|map(item => item.code)|join(', ') }}"
                                data-asset-name="{{ asset.name }}"
                            {% endif %}
                        >
                            <div class="flex items-center">
                                <div class="flex-shrink-0">
                                    <img src="{{ asset.thumbnailPath ? path('asset_thumbnail', {filename: asset.thumbnailPath|basename}) : '#' }}" alt="{{ asset.name }}" class="w-24 h-24 rounded-md object-cover bg-gray-200">
                                </div>
                                <div class="ml-6 flex-1 flex flex-col">
                                    <div>
                                        <div class="flex justify-between">
                                            <h4 class="text-sm">
                                                <a href="{{ path('app_asset', {id: asset.id}) }}" class="font-medium text-gray-700 hover:text-gray-800">{{ asset.name }}</a>
                                            </h4>
                                            <form action="{{ path('download_list_remove', {id: asset.id}) }}" method="post">
                                                <button type="submit" class="text-sm font-medium text-red-600 hover:text-red-500">
                                                    <span>Remove</span>
                                                </button>
                                            </form>
                                        </div>
                                        <p class="mt-1 text-sm text-gray-500">{{ asset.itemCodes|map(item => item.code)|join(', ') }}</p>
                                        <p class="mt-1 text-sm text-gray-500">{{ fileSizeMacro.format(asset.fileSize) }}</p>
                                        <p class="mt-1 text-sm text-gray-500">{{ asset.mimeType }}</p>
                                        {% if asset.mimeType in ['image/jpeg', 'image/png', 'image/webp', 'application/pdf'] %}
                                            <div class="permalink-container mt-2"></div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            {% if asset.colorSpace.value == 'cmyk' %}
                                <span class="absolute top-2 left-2 bg-yellow-400 text-yellow-900 text-xs font-bold px-2 py-1 rounded-full shadow">PRINT</span>
                            {% elseif asset.colorSpace.value == 'rgb' %}
                                <span class="absolute top-2 left-2 bg-gray-200 text-gray-700 text-xs font-bold px-2 py-1 rounded-full shadow">WEB</span>
                            {% endif %}

                            <div class="mt-4 pt-4 border-t border-gray-200 text-xs text-gray-600 grid grid-cols-2 gap-x-4 gap-y-2">

                                {% if asset.brand is not empty %}
                                    <div>
                                        <span class="font-semibold">Brands:</span>
                                        {{ asset.brand|map(b => b.brands ? '(' ~ b.brands.name ~ ') ' ~ b.name : b.name)|join(', ') }}
                                    </div>
                                {% endif %}
                                {% if asset.collections is not empty %}
                                    <div><span class="font-semibold">Collections:</span> {{ asset.collections|map(c => c.name)|join(', ') }}</div>
                                {% endif %}
                                {% if asset.categories is not empty %}
                                    <div><span class="font-semibold">Categories:</span> {{ asset.categories|map(c => c.name)|join(', ') }}</div>
                                {% endif %}
                                {% if asset.tags is not empty %}
                                    <div><span class="font-semibold">Tags:</span> {{ asset.tags|map(t => t.name)|join(', ') }}</div>
                                {% endif %}
                            </div>
                        </li>
                    {% endfor %}
                </ul>
            {% else %}
                <div class="text-center py-12 px-6">
                    <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                    </svg>
                    <h3 class="mt-2 text-sm font-medium text-gray-900">Your download bag is empty</h3>
                    <p class="mt-1 text-sm text-gray-500">Start by adding assets from the browse or search pages.</p>
                </div>
            {% endif %}
        </div>

        <div data-permalink-generator-target="modal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden">
            <div class="relative top-20 mx-auto p-5 border w-full max-w-lg shadow-lg rounded-md bg-white">
                <form data-action="submit->permalink-generator#generate">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Web Link Settings</h3>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="permalink_width" class="block text-sm font-medium text-gray-700">Width (px)</label>
                            <input type="number" id="permalink_width" data-permalink-generator-target="widthInput" class="mt-1 block w-full border-gray-300 rounded-md" required>
                        </div>
                        <div>
                            <label for="permalink_height" class="block text-sm font-medium text-gray-700">Height (px)</label>
                            <input type="number" id="permalink_height" data-permalink-generator-target="heightInput" class="mt-1 block w-full border-gray-300 rounded-md" required>
                        </div>
                        <div>
                            <label for="permalink_padding" class="block text-sm font-medium text-gray-700">Padding (px)</label>
                            <input type="number" id="permalink_padding" data-permalink-generator-target="paddingInput" placeholder="0" class="mt-1 block w-full border-gray-300 rounded-md">
                        </div>
                        <div>
                            <label for="permalink_extension" class="block text-sm font-medium text-gray-700">Format</label>
                            <select id="permalink_extension" data-permalink-generator-target="extensionInput" class="mt-1 block w-full border-gray-300 rounded-md">
                                <option value="webp">WebP</option>
                                <option value="jpg">JPG</option>
                                <option value="png">PNG</option>
                            </select>
                        </div>
                    </div>
                    <div class="mt-6 flex justify-end space-x-3">
                        <button type="button" data-action="click->permalink-generator#closeModal" class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50">Cancel</button>
                        <button type="submit" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-violet-600 hover:bg-violet-700">Generate Links</button>
                    </div>
                </form>
            </div>
        </div>

        <div data-download-bag-script-target="modal" data-action="click->download-bag-script#closeOnBackdrop" class="fixed inset-0 z-50 hidden items-center justify-center bg-gray-900/60 p-4">
            <div class="w-full max-w-3xl rounded-2xl bg-white shadow-2xl">
                <form action="{{ path('download_list_zip_scripted') }}" method="post" data-turbo="false" class="flex flex-col">
                    <div class="flex items-start justify-between border-b border-gray-200 px-6 py-5">
                        <div>
                            <h2 class="text-xl font-semibold text-gray-900">Apply Editor Script to Download Bag</h2>
                            <p class="mt-2 text-sm text-gray-500">Paste a canvas editor script to replay the same crop, image transform, and text layout across every supported raster asset in the bag.</p>
                        </div>
                        <button type="button" data-action="click->download-bag-script#closeModal" class="rounded-md border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                            Close
                        </button>
                    </div>

                    <div class="space-y-5 px-6 py-5">
                        <div class="grid gap-4 rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700 md:grid-cols-3">
                            <div>
                                <p class="font-semibold text-slate-900">Bag Assets</p>
                                <p class="mt-1"><span data-download-bag-script-target="totalCount">0</span> total items in the current download bag.</p>
                            </div>
                            <div>
                                <p class="font-semibold text-slate-900">Scriptable Assets</p>
                                <p class="mt-1"><span data-download-bag-script-target="compatibleCount">0</span> raster assets will receive the script.</p>
                            </div>
                            <div>
                                <p class="font-semibold text-slate-900">Skipped Assets</p>
                                <p class="mt-1"><span data-download-bag-script-target="skippedCount">0</span> non-raster or unreadable items will be skipped and listed in the zip report.</p>
                            </div>
                        </div>

                        <div data-download-bag-script-target="warning" class="hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900"></div>

                        <div>
                            <label for="download-bag-script-textarea" class="block text-sm font-medium text-gray-700">Editor Script JSON</label>
                            <textarea id="download-bag-script-textarea" name="script" data-download-bag-script-target="textarea" class="mt-2 h-80 w-full rounded-xl border border-gray-300 p-4 font-mono text-sm text-slate-700 focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-200" placeholder='{
  "version": 1,
  "sourceBounds": { "width": 0, "height": 0 },
  "crop": { "x": 0, "y": 0, "width": 1, "height": 1 },
  "baseImage": { "scale": 1, "offsetX": 0, "offsetY": 0 },
  "texts": []
}'></textarea>
                        </div>
                    </div>

                    <div class="flex items-center justify-between gap-3 border-t border-gray-200 px-6 py-4">
                        <p class="text-sm text-gray-500">This is session-local and download-only. Original assets in the bag are not modified.</p>
                        <div class="flex items-center gap-3">
                            <button type="button" data-action="click->download-bag-script#closeModal" class="rounded-md border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
                                Cancel
                            </button>
                            <button type="submit" data-download-bag-script-target="submitButton" class="inline-flex items-center justify-center rounded-md bg-violet-600 px-4 py-2 text-sm font-medium text-white hover:bg-violet-700 disabled:cursor-not-allowed disabled:opacity-50">
                                Download Edited Zip
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        {# Share Link Modal - Updated with name input #}
        <div data-share-link-target="modal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden">
            <div class="relative top-20 mx-auto p-5 border w-full max-w-md shadow-lg rounded-md bg-white">
                <form data-action="submit->share-link#generate" data-share-link-target="generateForm">
                    <div class="mt-3 text-center">
                        <h3 class="text-lg leading-6 font-medium text-gray-900">Generate Share Link</h3>
                        <div class="mt-4 px-7 py-3 text-left">
                            <label for="listName" class="block text-sm font-medium text-gray-700">List Name (Optional)</label>
                            <input type="text" data-share-link-target="nameInput" id="listName" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-violet-500 focus:border-violet-500">
                            <p class="mt-2 text-xs text-gray-500">
                                Give this list a name to save it for later use. Leave it blank to create a temporary, one-time link.
                            </p>
                        </div>
                        <div class="items-center px-4 py-3 bg-gray-50 rounded-b-md">
                            <button type="submit" data-share-link-target="button" class="px-4 py-2 bg-violet-600 text-white text-base font-medium rounded-md w-full shadow-sm hover:bg-violet-700">
                                Generate Link
                            </button>
                            <button type="button" data-action="click->share-link#closeModal" class="mt-2 px-4 py-2 bg-white text-gray-700 text-base font-medium rounded-md w-full shadow-sm border border-gray-300 hover:bg-gray-50">
                                Cancel
                            </button>
                        </div>
                    </div>
                </form>
                <div class="mt-3 text-center hidden" data-share-link-target="confirmation">
                    <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-green-100">
                        <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                    </div>
                    <h3 class="text-lg leading-6 font-medium text-gray-900 mt-2">Share Link Generated</h3>
                    <div class="mt-2 px-7 py-3">
                        <p class="text-sm text-gray-500 mb-4">
                            Anyone with this public link can download these assets. The link will expire in 30 days.
                        </p>
                        <div class="relative">
                            <input type="text" readonly data-share-link-target="urlInput" class="w-full bg-gray-100 border-gray-300 rounded-md p-2 pr-10 text-sm transition-colors duration-200">
                            <button data-action="click->share-link#copyToClipboard" class="absolute inset-y-0 right-0 pr-3 flex items-center">
                                <svg class="h-5 w-5 text-gray-500 hover:text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                            </button>
                        </div>
                    </div>
                    <div class="items-center px-4 py-3">
                        <button data-action="click->share-link#closeModal" class="px-4 py-2 bg-violet-500 text-white text-base font-medium rounded-md w-full shadow-sm hover:bg-violet-600">
                            Done
                        </button>
                    </div>
                </div>
            </div>
        </div>

