{% extends 'base.html.twig' %}

{% block title %}Edit {{ asset.name }} | {{ parent() }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('image-editor') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('image-editor') }}
{% endblock %}

{% block body %}
    <div
        {{ stimulus_controller('image-editor', {
            imageUrl: path('asset_stream', {id: asset.id}),
            assetName: asset.name,
            mimeType: asset.mimeType
        }) }}
        class="space-y-4"
    >
        <div class="rounded-2xl bg-white p-4 shadow-sm">
            <div class="flex flex-wrap items-center gap-2">
                <a href="{{ path('app_asset', {id: asset.id}) }}" class="inline-flex items-center rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">
                    Back to Asset
                </a>
                <button type="button" data-image-editor-target="undoButton" data-action="click->image-editor#undo" class="inline-flex items-center rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-50">
                    Undo
                </button>
                <button type="button" data-image-editor-target="redoButton" data-action="click->image-editor#redo" class="inline-flex items-center rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-50">
                    Redo
                </button>
                <button type="button" data-action="click->image-editor#resetEditor" class="inline-flex items-center rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">
                    Reset
                </button>
                <button type="button" data-action="click->image-editor#decreaseImageScale" class="inline-flex items-center rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">
                    Image -
                </button>
                <button type="button" data-action="click->image-editor#increaseImageScale" class="inline-flex items-center rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">
                    Image +
                </button>
                <span data-image-editor-target="imageScaleLabel" class="rounded-lg bg-slate-100 px-3 py-2 text-sm font-medium text-slate-600">
                    100%
                </span>
                <button type="button" data-action="click->image-editor#copyScript" class="inline-flex items-center rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">
                    Copy Script
                </button>
                <button type="button" data-action="click->image-editor#openPasteModal" class="inline-flex items-center rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">
                    Paste Script
                </button>
                <button type="button" data-action="click->image-editor#downloadImage" class="inline-flex items-center rounded-lg bg-violet-600 px-3 py-2 text-sm font-medium text-white hover:bg-violet-700">
                    Download
                </button>
            </div>
            <p data-image-editor-target="status" class="mt-3 text-sm text-slate-500">
                Select mode lets you drag the image and use the mouse wheel to zoom. Use Crop to adjust the export frame or Text to add a new text layer.
            </p>
        </div>

        <div class="grid gap-4 xl:grid-cols-[4.5rem,minmax(0,1fr),21rem]">
            <aside class="image-editor-tool-rail h-fit rounded-2xl bg-slate-900 p-2 shadow-sm">
                <div class="image-editor-toolbar flex flex-col gap-2">
                    <button type="button" data-action="click->image-editor#setTool" data-tool="select" title="Select" class="image-editor-tool-button is-active">
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <path d="M5 4.5v14l4.4-4.4 2.7 5.4 2.3-1.1-2.7-5.5 6.1-.9L5 4.5Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"/>
                        </svg>
                        <span class="sr-only">Select</span>
                    </button>
                    <button type="button" data-action="click->image-editor#setTool" data-tool="text" title="Text" class="image-editor-tool-button">
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <path d="M6 6.5h12M12 6.5v11M8.5 17.5h7" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"/>
                        </svg>
                        <span class="sr-only">Text</span>
                    </button>
                    <button type="button" data-action="click->image-editor#setTool" data-tool="crop" title="Crop" class="image-editor-tool-button">
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <path d="M7 4.5v10.5a2 2 0 0 0 2 2h10.5M4.5 7H15a2 2 0 0 1 2 2v10.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"/>
                        </svg>
                        <span class="sr-only">Crop</span>
                    </button>
                </div>
            </aside>

            <section class="rounded-2xl bg-white p-4 shadow-sm">
                <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
                    <div>
                        <h1 class="text-xl font-semibold text-slate-900">Canvas Editor</h1>
                        <p class="text-sm text-slate-500">{{ asset.name }}</p>
                    </div>
                    <div class="flex flex-wrap items-center gap-2">
                        <span data-image-editor-target="selectionSummary" class="rounded-full bg-slate-100 px-3 py-1 text-sm text-slate-600">
                            No text selected
                        </span>
                        <span data-image-editor-target="cropSummary" class="rounded-full bg-slate-100 px-3 py-1 text-sm text-slate-600">
                            Crop: 100%
                        </span>
                    </div>
                </div>

                <div data-image-editor-target="workspace" class="image-editor-workspace relative h-[70vh] min-h-[32rem] overflow-hidden rounded-2xl border border-slate-200 bg-slate-100">
                    <div data-image-editor-target="surface" class="image-editor-surface absolute">
                        <canvas data-image-editor-target="canvas" class="absolute inset-0 h-full w-full"></canvas>
                        <div data-image-editor-target="overlay" class="image-editor-overlay absolute inset-0">
                            <div data-image-editor-target="cropBox" class="image-editor-crop-box">
                                <span class="image-editor-handle image-editor-handle-tl"></span>
                                <span class="image-editor-handle image-editor-handle-tr"></span>
                                <span class="image-editor-handle image-editor-handle-bl"></span>
                                <span class="image-editor-handle image-editor-handle-br"></span>
                            </div>
                            <div data-image-editor-target="textLayer" class="absolute inset-0"></div>
                        </div>
                    </div>
                    <div data-image-editor-target="loadingState" class="absolute inset-0 flex items-center justify-center text-sm font-medium text-slate-500">
                        Loading image…
                    </div>
                </div>
            </section>

            <aside class="image-editor-sidebar h-fit overflow-hidden rounded-2xl bg-slate-900 text-slate-100 shadow-sm">
                <div class="border-b border-white/10 p-4">
                    <div class="mb-4 flex items-start justify-between gap-3">
                        <div>
                            <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-slate-400">Properties</p>
                            <h2 class="mt-1 text-lg font-semibold text-white">Selected Layer</h2>
                        </div>
                        <span data-image-editor-target="layerCount" class="rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-slate-300">
                            2 layers
                        </span>
                    </div>

                    <div data-image-editor-target="propertiesEmptyState" class="rounded-xl border border-white/10 bg-white/5 px-4 py-4 text-sm text-slate-300">
                        <p data-image-editor-target="propertiesEmptyTitle" class="font-semibold text-white">Base image selected</p>
                        <p data-image-editor-target="propertiesEmptyMessage" class="mt-1 text-slate-400">Select a text layer from the canvas or Layers to edit its properties.</p>
                    </div>

                    <div data-image-editor-target="textInspector" class="hidden space-y-4">
                        <div class="rounded-xl border border-white/10 bg-white/5 px-4 py-3">
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Text Properties</p>
                            <p class="mt-1 text-sm text-slate-300">Selected text layers update live on the canvas.</p>
                        </div>

                        <div>
                            <label for="image-editor-font-family" class="mb-1 block text-sm font-medium text-slate-200">Font</label>
                            <select id="image-editor-font-family" data-image-editor-target="fontFamilySelect" data-action="change->image-editor#changeSelectedTextStyle" data-style-property="fontFamily" class="w-full rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm text-slate-100 focus:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-400/20">
                                <option value="Arial">Arial</option>
                                <option value="Helvetica">Helvetica</option>
                                <option value="Georgia">Georgia</option>
                                <option value="Times New Roman">Times New Roman</option>
                                <option value="Trebuchet MS">Trebuchet MS</option>
                                <option value="Verdana">Verdana</option>
                                <option value="Tahoma">Tahoma</option>
                                <option value="Courier New">Courier New</option>
                                <option value="Impact">Impact</option>
                            </select>
                        </div>

                        <div>
                            <label for="image-editor-font-size" class="mb-1 block text-sm font-medium text-slate-200">Font Size</label>
                            <input id="image-editor-font-size" type="number" min="8" step="1" data-image-editor-target="fontSizeInput" data-action="change->image-editor#changeSelectedTextStyle" data-style-property="fontSize" class="w-full rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm text-slate-100 focus:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-400/20">
                        </div>

                        <div>
                            <label for="image-editor-font-color" class="mb-1 block text-sm font-medium text-slate-200">Text Color</label>
                            <input id="image-editor-font-color" type="color" data-image-editor-target="colorInput" data-action="change->image-editor#changeSelectedTextStyle" data-style-property="color" class="image-editor-color-input h-11 w-full rounded-lg border border-white/10 bg-white/5 px-1 py-1">
                        </div>

                        <div class="space-y-2">
                            <span class="block text-sm font-medium text-slate-200">Style</span>
                            <div class="grid grid-cols-2 gap-2">
                                <button type="button" data-image-editor-target="boldButton" data-action="click->image-editor#toggleSelectedTextStyle" data-style-property="fontWeight" data-style-value="bold" data-default-value="normal" class="rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm font-medium text-slate-100 hover:bg-white/10">
                                    Bold
                                </button>
                                <button type="button" data-image-editor-target="italicButton" data-action="click->image-editor#toggleSelectedTextStyle" data-style-property="fontStyle" data-style-value="italic" data-default-value="normal" class="rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm font-medium text-slate-100 hover:bg-white/10">
                                    Italic
                                </button>
                            </div>
                        </div>

                        <div class="space-y-2">
                            <span class="block text-sm font-medium text-slate-200">Alignment</span>
                            <div class="grid grid-cols-3 gap-2">
                                <button type="button" data-image-editor-target="alignButton" data-action="click->image-editor#setSelectedTextAlign" data-style-value="left" class="rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm font-medium text-slate-100 hover:bg-white/10">
                                    Left
                                </button>
                                <button type="button" data-image-editor-target="alignButton" data-action="click->image-editor#setSelectedTextAlign" data-style-value="center" class="rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm font-medium text-slate-100 hover:bg-white/10">
                                    Center
                                </button>
                                <button type="button" data-image-editor-target="alignButton" data-action="click->image-editor#setSelectedTextAlign" data-style-value="right" class="rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm font-medium text-slate-100 hover:bg-white/10">
                                    Right
                                </button>
                            </div>
                        </div>

                        <button type="button" data-action="click->image-editor#deleteSelectedText" class="w-full rounded-lg border border-red-400/40 bg-red-500/10 px-3 py-2 text-sm font-medium text-red-200 hover:bg-red-500/20">
                            Delete Text
                        </button>
                    </div>
                </div>

                <div class="p-4">
                    <div class="mb-3">
                        <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-slate-400">Layers</p>
                        <h3 class="mt-1 text-lg font-semibold text-white">Stack Order</h3>
                        <p class="text-sm text-slate-400">Top layers appear first in the list.</p>
                    </div>

                    <div data-image-editor-target="layersList" class="max-h-[24rem] space-y-2 overflow-y-auto pr-1"></div>
                </div>
            </aside>
        </div>

        <div data-image-editor-target="scriptModal" data-action="click->image-editor#closeScriptModalOnBackdrop" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/60 p-4">
            <div class="w-full max-w-2xl rounded-2xl bg-white p-5 shadow-2xl">
                <div class="mb-4 flex items-center justify-between">
                    <div>
                        <h2 data-image-editor-target="scriptModalTitle" class="text-lg font-semibold text-slate-900">Paste Script</h2>
                        <p data-image-editor-target="scriptModalHint" class="text-sm text-slate-500">Paste an editor script to replace the current canvas state.</p>
                    </div>
                    <button type="button" data-action="click->image-editor#closeScriptModal" class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">
                        Close
                    </button>
                </div>

                <textarea data-image-editor-target="scriptTextarea" class="h-72 w-full rounded-xl border border-slate-300 p-3 font-mono text-sm text-slate-700 focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-200"></textarea>

                <div class="mt-4 flex items-center justify-end gap-2">
                    <button type="button" data-action="click->image-editor#closeScriptModal" class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">
                        Cancel
                    </button>
                    <button type="button" data-image-editor-target="scriptConfirmButton" data-action="click->image-editor#confirmScriptModal" class="rounded-lg bg-violet-600 px-3 py-2 text-sm font-medium text-white hover:bg-violet-700">
                        Apply Script
                    </button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
